{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchcomputer.com/spec/tool-schema.v1.schema.json",
  "title": "Tool input schema declaration (v1)",
  "description": "A JSON Schema fragment describing a tool's input shape, plus the x-capabilities meta keyword.",
  "type": "object",
  "required": ["schema_version", "name", "input_schema", "x-capabilities"],
  "properties": {
    "schema_version": { "const": "1" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "input_schema": {
      "type": "object",
      "description": "A JSON Schema fragment for the tool's input."
    },
    "x-capabilities": {
      "type": "array",
      "items": { "enum": ["fs:read", "fs:write", "process:spawn", "network:egress", "git:mutate", "mcp:call"] },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
