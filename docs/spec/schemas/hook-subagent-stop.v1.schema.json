{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchcomputer.com/spec/hook-subagent-stop.v1.schema.json",
  "title": "SubagentStop hook payload (v1)",
  "type": "object",
  "required": ["schema_version", "session_id", "trace_id", "cwd", "agent_name", "teammate_name", "task_id", "termination_reason"],
  "properties": {
    "schema_version": { "const": "1" },
    "session_id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "trace_id": { "type": "string", "minLength": 1 },
    "cwd": { "type": "string", "minLength": 1 },
    "agent_name": { "type": "string", "minLength": 1 },
    "teammate_name": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "termination_reason": { "enum": ["taskComplete", "budgetExhausted", "parentAbort", "error"] }
  },
  "additionalProperties": false
}
