{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchcomputer.com/spec/hook-post-tool-use.v1.schema.json",
  "title": "PostToolUse hook payload (v1)",
  "type": "object",
  "required": ["schema_version", "session_id", "trace_id", "cwd", "agent_name", "tool_name", "tool_args", "tool_result"],
  "properties": {
    "schema_version": { "const": "1" },
    "session_id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "trace_id": { "type": "string", "minLength": 1 },
    "cwd": { "type": "string", "minLength": 1 },
    "agent_name": { "type": "string", "minLength": 1 },
    "tool_name": { "type": "string", "minLength": 1 },
    "tool_args": {},
    "tool_result": {}
  },
  "additionalProperties": false
}
