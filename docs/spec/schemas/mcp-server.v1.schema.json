{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchcomputer.com/spec/mcp-server.v1.schema.json",
  "title": "MCP server config file (v1)",
  "type": "object",
  "required": ["schema_version", "servers"],
  "properties": {
    "schema_version": { "const": "1" },
    "servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "transport"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "transport": { "enum": ["stdio", "sse", "http"] },
          "command": { "type": "string" },
          "args": { "type": "array", "items": { "type": "string" } },
          "env": { "type": "object", "additionalProperties": { "type": "string" } },
          "url": { "type": "string", "format": "uri" },
          "headers": { "type": "object", "additionalProperties": { "type": "string" } },
          "trust_level": { "enum": ["trusted", "untrusted"] }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": { "properties": { "transport": { "const": "stdio" } }, "required": ["transport"] },
            "then": { "required": ["command"] }
          },
          {
            "if": { "properties": { "transport": { "enum": ["sse", "http"] } }, "required": ["transport"] },
            "then": { "required": ["url"] }
          }
        ]
      }
    },
    "ext": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z0-9_-]+(?:\\.[a-z0-9_-]+)*$" },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
