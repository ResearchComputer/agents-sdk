{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchcomputer.com/spec/session.v1.schema.json",
  "title": "Session snapshot (v1)",
  "description": "Checkpoint and pointer into a trajectory. Messages are reconstructed by replaying the trajectory up to last_event_id. context_state captures non-replayable runtime state (cost totals, selected memories, interrupted tool calls) that cannot be derived from the trajectory.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "trajectory_id",
    "last_event_id",
    "model_id",
    "provider_name",
    "system_prompt_hash",
    "memory_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "id": { "type": "string", "minLength": 1 },
    "trajectory_id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "last_event_id": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
        { "type": "null" }
      ]
    },
    "model_id": { "type": "string", "minLength": 1 },
    "provider_name": { "type": "string", "minLength": 1 },
    "system_prompt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "memory_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "compaction_state": {
      "type": "object",
      "required": ["last_compacted_event_id"],
      "properties": {
        "last_compacted_event_id": {
          "oneOf": [
            { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
            { "type": "null" }
          ]
        },
        "summary": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    },
    "context_state": {
      "type": "object",
      "required": ["selected_memories", "cost_state", "interrupted_tool_call_ids"],
      "properties": {
        "cwd": { "type": "string" },
        "selected_memories": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "score", "updated_at"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "score": { "type": "number" },
              "updated_at": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "cost_state": {
          "type": "object",
          "required": ["total_tokens", "total_cost", "per_model"],
          "properties": {
            "total_tokens": { "type": "number", "minimum": 0 },
            "total_cost": { "type": "number", "minimum": 0 },
            "per_model": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["model_id", "tokens", "cost"],
                "properties": {
                  "model_id": { "type": "string", "minLength": 1 },
                  "tokens": { "type": "number", "minimum": 0 },
                  "cost": { "type": "number", "minimum": 0 }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "interrupted_tool_call_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "swarm_state": { "type": "object" },
        "ext": {
          "type": "object",
          "propertyNames": { "pattern": "^[a-z0-9_-]+(?:\\.[a-z0-9_-]+)*$" },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "ext": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z0-9_-]+(?:\\.[a-z0-9_-]+)*$" },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
